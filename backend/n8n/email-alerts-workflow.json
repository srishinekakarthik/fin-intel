{
  "name": "FinIntel — Email Alerts",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "finintel-email",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-email-node",
      "name": "Webhook: Receive Email Request",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [
        200,
        300
      ],
      "webhookId": "finintel-email-webhook"
    },
    {
      "parameters": {
        "sendTo": "={{ $json.body.to }}",
        "subject": "={{ $json.body.subject }}",
        "message": "={{ $json.body.html }}",
        "appendAttribution": false,
        "options": {}
      },
      "id": "gmail-send-node",
      "name": "Gmail",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        420,
        300
      ],
      "credentials": {
        "gmailOAuth2": {
          "id": "YOUR_GMAIL_CREDS_ID",
          "name": "Gmail account"
        }
      }
    }
  ],
  "pinData": {},
  "connections": {
    "Webhook: Receive Email Request": {
      "main": [
        [
          {
            "node": "Gmail",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": []
}
