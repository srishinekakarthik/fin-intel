# ── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Supabase ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-32+-char-string
JWT_EXPIRES_IN=7d

# ── AI — Gemini only ─────────────────────────────────────
# Embeddings: text-embedding-004 (768 dims) — used by n8n
# Chat/generation: gemini-1.5-pro — used by backend RAG
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# ── Market data ───────────────────────────────────────────
FINNHUB_API_KEY=your-finnhub-key
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com

# ── n8n Cloud ────────────────────────────────────────────
# Your n8n Cloud instance base URL (no trailing slash)
# Format: https://your-instance.app.n8n.cloud/webhook
N8N_WEBHOOK_BASE_URL=https://your-instance.app.n8n.cloud/webhook

# n8n API key (from n8n Cloud → Settings → API)
N8N_API_KEY=your-n8n-api-key

# The webhook path UUID from your ingestion workflow's Webhook node
# e.g. if webhook URL is https://your-instance.app.n8n.cloud/webhook/abc-123
# then set: N8N_INGESTION_WEBHOOK_PATH=abc-123
N8N_INGESTION_WEBHOOK_PATH=your-ingestion-webhook-path

# Shared secret so the backend can verify callbacks FROM n8n are legitimate
# Set the same value in your n8n workflow HTTP Request node header: X-Callback-Secret
N8N_CALLBACK_SECRET=generate-a-random-secret-here

# URL to your n8n Email Webhook
N8N_EMAIL_WEBHOOK_URL=your-email-webhook-url
